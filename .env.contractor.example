# Contractor dispatch mailbox polling
# Copy these into .env.contractor on the Pi/container and restart the contractor app.
DISPATCH_MAILBOX_HOST=imap.ionos.com
DISPATCH_MAILBOX_PORT=993
DISPATCH_MAILBOX_USER=orders@greenhillssupply.com
DISPATCH_MAILBOX_PASSWORD=replace-with-mailbox-app-password
DISPATCH_MAILBOX_NAME=INBOX
DISPATCH_MAILBOX_LIMIT=10
DISPATCH_MAILBOX_BACKFILL_LIMIT=250
DISPATCH_MAILBOX_MARK_SEEN=false
DISPATCH_MAILBOX_SUBJECT_PREFIX=You've Got A New Order: #

# Direct Shopify order import for new website orders.
# The app must have read_orders in SCOPES, then be reinstalled/reauthorized.
SHOPIFY_STORE_DOMAIN=your-shop.myshopify.com
DISPATCH_SHOPIFY_IMPORT_LIMIT=25
DISPATCH_SHOPIFY_ORDER_QUERY=status:open fulfillment_status:unfulfilled

# When true, Dispatch will poll the mailbox when the page loads,
# no more often than DISPATCH_MAILBOX_POLL_SECONDS.
DISPATCH_MAILBOX_AUTO_POLL=false
DISPATCH_MAILBOX_POLL_SECONDS=300

# Optional: set this and call /api/dispatch-poll-mailbox?secret=...
# from cron for true unattended polling.
DISPATCH_POLL_SECRET=replace-with-long-random-secret

# Leave false/omitted in production so deleted demo orders do not come back.
DISPATCH_SEED_EXAMPLE_ORDERS=false

# Supabase auth / role settings
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are already used by the app for data access.
# SUPABASE_ANON_KEY is used for email/password sign-in.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
USER_AUTH_COOKIE_SECRET=replace-with-long-random-secret

# Kenect customer texting
# Ask Kenect for the API endpoint/API key for outbound messages, or use the
# webhook URL they provide for an integration workflow.
KENECT_API_URL=https://replace-with-kenect-outbound-message-endpoint
KENECT_API_KEY=replace-with-kenect-api-key
KENECT_LOCATION_ID=replace-with-kenect-location-or-business-id
KENECT_FROM_NUMBER=replace-with-kenect-number-if-required

# Delivery confirmation email
# Verify ghstickets.com with Resend, then send from your domain.
RESEND_API_KEY=replace-with-resend-api-key
DELIVERY_CONFIRMATION_FROM=Green Hills Supply <dispatch@ghstickets.com>
DELIVERY_CONFIRMATION_REPLY_TO=info@greenhillssupply.com
