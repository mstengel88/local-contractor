# Contractor dispatch mailbox polling
# Copy these into .env.contractor on the Pi/container and restart the contractor app.
DISPATCH_MAILBOX_HOST=imap.ionos.com
DISPATCH_MAILBOX_PORT=993
DISPATCH_MAILBOX_USER=orders@greenhillssupply.com
DISPATCH_MAILBOX_PASSWORD=replace-with-mailbox-app-password
DISPATCH_MAILBOX_NAME=INBOX
DISPATCH_MAILBOX_LIMIT=10
DISPATCH_MAILBOX_MARK_SEEN=false
DISPATCH_MAILBOX_SUBJECT_PREFIX=You've Got A New Order: #

# When true, Dispatch will poll the mailbox when the page loads,
# no more often than DISPATCH_MAILBOX_POLL_SECONDS.
DISPATCH_MAILBOX_AUTO_POLL=false
DISPATCH_MAILBOX_POLL_SECONDS=300

# Optional: set this and call /api/dispatch-poll-mailbox?secret=...
# from cron for true unattended polling.
DISPATCH_POLL_SECRET=replace-with-long-random-secret
